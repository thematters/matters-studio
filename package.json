{
  "name": "matters-studio-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Matters Studio — internal tooling app for the Matters team. Phase 9.1 MVP: OG Image wizard.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thematters/matters-studio.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @matters-studio/web dev",
    "dev:api": "pnpm --filter @matters-studio/api dev",
    "build": "pnpm -r --filter \"./apps/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,css}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
